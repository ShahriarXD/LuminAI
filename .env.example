# Public client-side variables for the Vite app.
# Safe to add in Vercel Project Settings -> Environment Variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Server-side secrets such as GROQ_API_KEY, LOVABLE_API_KEY, and
# SUPABASE_SERVICE_ROLE_KEY are used by Supabase Edge Functions, not by Vercel.
